{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2023",
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": [
    "src/core/**/*",
    "src/react.ts",
    "src/index.ts",
    "src/react/**/*"
  ],
  "exclude": [
    "src/**/*.test.*",
    "src/**/*.stories.*",
    "src/react/stories/**",
    "src/main.tsx",
    "src/App.tsx"
  ]
}
